# =============================================================================
# LiveEye — Variáveis de ambiente (copia este ficheiro para .env e preenche)
# =============================================================================
# 1. Copia: cp .env.example .env   (Linux/macOS)
#          copy .env.example .env   (Windows)
# 2. Preenche os valores abaixo com os teus dados
# =============================================================================

# ── Qdrant (base de dados vectorial) ─────────────────────────────────────────
# Cria uma conta gratuita em https://cloud.qdrant.io e um cluster.
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.eu-west-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── MySQL ────────────────────────────────────────────────────────────────────
# Precisa de um servidor MySQL/MariaDB a correr.
# O schema está em BD/schema_liveeyedetect.sql — importa antes de usar.
MySQL_HOST=localhost
MySQL_PORT=3306
MySQL_USER=your_mysql_user
MySQL_PASSWORD=your_mysql_password
MySQL_DATABASE=liveeyedetect

# ── Gmail SMTP (para recuperação de password) ────────────────────────────────
# Cria uma "App Password" em https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Admin ────────────────────────────────────────────────────────────────────
# Email e password do utilizador admin (para gerar convites de registo).
# O admin tem de existir primeiro na tabela `utilizadores`.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
